# ─── ThreatScope Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit it.

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_INDEX=threatscope-events
ES_USER=
ES_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=threatscope-logs

# ── AI Engine ─────────────────────────────────────────────────────────────────
ANOMALY_BLOCK_THRESHOLD=0.75
ANOMALY_ALERT_THRESHOLD=0.50
IPS_DRY_RUN=true

# ── Log Path ──────────────────────────────────────────────────────────────────
LOG_PATH=logs/network.log

# ── Threat Intel API Keys (optional) ─────────────────────────────────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
